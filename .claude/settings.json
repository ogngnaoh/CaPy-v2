{
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(pytest *)",
      "Bash(python scripts/*)",
      "Bash(ruff *)",
      "Bash(black *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "ruff check --fix \"$TOOL_INPUT_file_path\" 2>/dev/null; ruff format \"$TOOL_INPUT_file_path\" 2>/dev/null; true"
      }
    ]
  }
}
